{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rabit",
  "colors": {
    "primary": "#FD4C01",
    "light": "#FAFAFA",
    "dark": "#262626"
  },
  "favicon": "/favicon.png",
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "light": "#EFEFEF",
      "dark": "#010101"
    }
  },
  "api": {
    "baseUrl": "http://localhost:8000",
    "auth": {
      "method": "bearer",
      "name": "Authorization",
      "inputPrefix": "Bearer "
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "getting-started/run/quickstart"
            ]
          }
        ]
      },
      {
        "tab": "Rabit Backend",
        "groups": [
          {
            "group": "Features",
            "expanded": false,
            "pages": [
              "features/index",
              "features/agent/index",
              "features/execution/index"
            ]
          },
          {
            "group": "Architecture",
            "expanded": false,
            "pages": [
              "architecture/index",
              "architecture/system/index",
              "architecture/data-layer"
            ]
          },
          {
            "group": "Agents",
            "expanded": false,
            "pages": [
              "agents/index",
              "agents/runtime/structure",
              "agents/auth/wallet-auth",
              "agents/routing/intent-routing"
            ]
          },
          {
            "group": "Integrations",
            "expanded": false,
            "pages": [
              "integrations/index",
              "integrations/backpack/index",
              "integrations/drift/index",
              "integrations/openrouter/index",
              "integrations/mem0/index",
              "integrations/coingecko/index"
            ]
          },
          {
            "group": "WebSocket and data",
            "expanded": false,
            "pages": [
              "websocket/overview",
              "websocket/data-sources",
              "websocket/backpack/index",
              "websocket/drift/index",
              "websocket/binance/index"
            ]
          },
          {
            "group": "Tools",
            "expanded": false,
            "pages": [
              "tools/index",
              "tools/market/index",
              "tools/tradingview/index",
              "tools/execution",
              "tools/decision-support",
              "tools/memory",
              "tools/ui-streaming"
            ]
          },
          {
            "group": "Development",
            "expanded": false,
            "pages": [
              "development/index",
              "development/setup/index"
            ]
          }
        ]
      },
      {
        "tab": "Rabit Mobile",
        "groups": [
          {
            "group": " ",
            "pages": [
              "mobile/index"
            ]
          }
        ]
      },
      {
        "tab": "Rabit Contract",
        "groups": [
          {
            "group": " ",
            "pages": [
              "contract/index"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/design"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "api-reference/auth",
              "api-reference/agent",
              "api-reference/exchange-connections",
              "api-reference/drift"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/rabit-logo-light.png",
    "dark": "/logo/rabit-logo-dark.png"
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  }
}
